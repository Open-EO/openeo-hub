    "express": "^5.2.1",
    "moment": "^2.30.0",
    "vue": "^3.0.0",
    "vue-multiselect": "^2.1.9",
    "vue2-leaflet": "^1.2.3"
  },
  "devDependencies": {
    "@vue/cli-service": "^5.0.9",
    "sass": "^1.98.0",
